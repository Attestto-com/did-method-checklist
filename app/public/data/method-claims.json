    "did:sns": {
      "focalUseCase": "Cross-Border Finance",
      "stage": "Development",
      "regions": [
        "Global",
        "LATAM",
        "EU"
      ],
      "npm": {
        "package": "@attestto/did-sns-resolver",
        "url": "https://www.npmjs.com/package/@attestto/did-sns-resolver"
      },
      "useCaseSummary": "Cross-border identity for regulated finance \u2014 stablecoin corridors, KYC/AML credential exchange, and legal entity binding via vLEI. Also supports academic credentials, healthcare consent, and encrypted messaging via DIDComm v2.",
      "useCaseSource": "https://github.com/Attestto-com/did-sns-spec/blob/main/did-sns/spec/03-focal-use-cases.md",
      "reqSatisfaction": {
        "R1": "Controller proves ownership via Ed25519/secp256k1/ML-DSA-44 signature on a challenge. Spec \u00a74.2 defines verification method resolution.",
        "R2": "Controller creates DID without central authority \u2014 PDA derived from domain hash on Solana. No registration needed beyond an on-chain transaction.",
        "R3": "Registry enforces global uniqueness via Solana PDA derivation \u2014 same domain hash always maps to same account, collisions impossible.",
        "R4": "Resolution reads from public Solana registry and IPFS. No need to contact the issuer \u2014 any resolver node can verify independently.",
        "R5": "DID Document includes Ed25519, secp256k1, and ML-DSA-44 verification methods. Keys are bound to the DID at creation.",
        "R6": "DID Document update operation rotates keys without changing the DID identifier. Spec \u00a75.3 defines the update protocol.",
        "R7": "DID Document supports service endpoints for DIDComm v2, credential exchange, and linked domains. Spec \u00a74.4.",
        "R8": "No PII stored on-chain. Selective Disclosure via SD-JWT for credential presentations. Domain names are pseudonymous.",
        "R9": "Multi-sig controller support \u2014 multiple keys can be authorized as controllers with threshold signing.",
        "R10": "Works on Solana (global, permissionless). No jurisdiction-specific infrastructure required.",
        "R11": "No single authority can revoke the DID. Only the controller's private key can deactivate it.",
        "R12": "Minimal Solana rent (~0.002 SOL) for on-chain account. No per-transaction fees for resolution.",
        "R13": "Open-source spec and tooling. Standard DID Document format. Universal Resolver driver available.",
        "R14": "SD-JWT selective disclosure limits data exposure. Pairwise DIDs possible for privacy-sensitive contexts.",
        "R15": "ML-DSA-44 (CRYSTALS-Dilithium) and ML-KEM-768 post-quantum algorithms supported as verification methods.",
        "R16": "Data lives on Solana (decentralized, replicated) + IPFS. Survives even if Attestto ceases to exist.",
        "R17": "Not tied to a single software deployment. Any compatible resolver can read the on-chain state.",
        "R18": "Controller retains keys independent of any service provider. DID is bound to cryptographic keys, not a business relationship.",
        "R19": "DIDComm v2 encrypted messaging channel. End-to-end encryption with authenticated key agreement.",
        "R20": "Primary registry is Solana, but the method spec allows alternate registries implementing the same PDA derivation interface.",
        "R21": "DID binds to legal identity via vLEI verifiable credential. Supports eIDAS and FATF compliance frameworks.",
        "R22": "Human-readable SNS domain names (e.g. alice.sol) resolve to DID Documents. No need to memorize cryptographic hashes."
      },
      "industries": [
        {
          "id": "cross-border-finance",
          "evidence": "Section 3.1 \u2014 stablecoin corridors, SWIFT/IBAN replacement, ISO 20022 compliance",
          "source": "https://github.com/Attestto-com/did-sns-spec/blob/main/did-sns/spec/03-focal-use-cases.md"
        },
        {
          "id": "banking-kyc",
          "evidence": "Section 3.1 \u2014 FATF Travel Rule, KYC credential exchange, sanctions screening",
          "source": "https://github.com/Attestto-com/did-sns-spec/blob/main/did-sns/spec/03-focal-use-cases.md"
        },
        {
          "id": "defi-identity",
          "evidence": "Section 3.1 \u2014 SBT minting, on-chain reputation, wallet-bound credentials",
          "source": "https://github.com/Attestto-com/did-sns-spec/blob/main/did-sns/spec/03-focal-use-cases.md"
        },
        {
          "id": "government-eid",
          "evidence": "Section 3.2 \u2014 eIDAS compliance, national eID binding, public authority credentials",
          "source": "https://github.com/Attestto-com/did-sns-spec/blob/main/did-sns/spec/03-focal-use-cases.md"
        },
        {
          "id": "academic-credentials",
          "evidence": "Section 3.3 \u2014 university degrees, micro-credentials, transcript portability",
          "source": "https://github.com/Attestto-com/did-sns-spec/blob/main/did-sns/spec/03-focal-use-cases.md"
        },
        {
          "id": "patient-health",
          "evidence": "Section 3.4 \u2014 prescription verification, consent-gated health records",
          "source": "https://github.com/Attestto-com/did-sns-spec/blob/main/did-sns/spec/03-focal-use-cases.md"
        },
        {
          "id": "messaging",
          "evidence": "Section 3.5 \u2014 DIDComm v2 encrypted messaging, provider-portable channels",
          "source": "https://github.com/Attestto-com/did-sns-spec/blob/main/did-sns/spec/03-focal-use-cases.md"
        },
        {
          "id": "supply-chain",
          "evidence": "Section 3.6 \u2014 product provenance, trade document credentials",
          "source": "https://github.com/Attestto-com/did-sns-spec/blob/main/did-sns/spec/03-focal-use-cases.md"
        }
      ]
    },
